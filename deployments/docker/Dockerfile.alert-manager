FROM golang:1.22-alpine AS builder
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /bin/alert-manager ./cmd/alert-manager

FROM gcr.io/distroless/static-debian12
COPY --from=builder /bin/alert-manager /alert-manager
EXPOSE 8082
ENTRYPOINT ["/alert-manager"]
