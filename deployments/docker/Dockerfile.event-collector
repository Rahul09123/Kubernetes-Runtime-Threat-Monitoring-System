FROM golang:1.25-alpine AS builder
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /bin/event-collector ./cmd/event-collector

FROM gcr.io/distroless/static-debian12
COPY --from=builder /bin/event-collector /event-collector
EXPOSE 8080
ENTRYPOINT ["/event-collector"]
